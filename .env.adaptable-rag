# ──────────────────────────────────────────────────────────────────────────────
# EMBEDDING PROVIDER API KEYS
# ──────────────────────────────────────────────────────────────────────────────
# Required for cloud-hosted embedding models. Uncomment and set the API keys
# for the providers you want to use.
# ──────────────────────────────────────────────────────────────────────────────

# ── OpenAI Embeddings ──
# Models: text-embedding-3-small (1536 dims), text-embedding-3-large (3072 dims)
# Sign up: https://platform.openai.com/api-keys
# Pricing: $0.02-0.13 per 1M tokens
# OPENAI_API_KEY=<REDACTED>

# ── Cohere Embeddings ──
# Models: embed-english-v3.0 (1024 dims), embed-multilingual-v3.0 (1024 dims)
# Sign up: https://dashboard.cohere.com/api-keys
# Pricing: $0.10 per 1M tokens
# Features: Binary compression (int8, uint8, binary, ubinary)
# COHERE_API_KEY=...

# ── Voyage AI Embeddings ──
# Models: voyage-large-2 (1536 dims), voyage-finance-2 (1024 dims for financial docs)
# Sign up: https://dash.voyageai.com/
# Pricing: $0.10-0.12 per 1M tokens
# Strengths: Domain-specific models (code, law, finance)
# VOYAGE_API_KEY=pa-...

# ── Google Generative AI Embeddings ──
# Models: text-embedding-004 (768 dims), text-embedding-005 (768 dims)
# Sign up: https://makersuite.google.com/app/apikey
# Pricing: $0.01 per 1M tokens (very cost-effective!)
# GOOGLE_API_KEY=...

# ── Jina AI Embeddings ──
# Models: jina-embeddings-v2-base-en (768 dims), jina-embeddings-v3 (1024 dims)
# Sign up: https://jina.ai/embeddings/
# Pricing: $0.01-0.02 per 1M tokens
# Strengths: 8K context window, multilingual support
# JINA_API_KEY=...

# ──────────────────────────────────────────────────────────────────────────────
# RERANKING PROVIDER API KEYS
# ──────────────────────────────────────────────────────────────────────────────

# ── Cohere Reranking ──
# Models: rerank-english-v3.0, rerank-multilingual-v3.0
# Uses same API key as Cohere embeddings above
# Pricing: $2.00 per 1M tokens

# ── Voyage AI Reranking ──
# Models: rerank-lite-1
# Uses same API key as Voyage embeddings above
# Pricing: $0.50 per 1M tokens

# ──────────────────────────────────────────────────────────────────────────────
# LLM PROVIDER API KEYS
# ──────────────────────────────────────────────────────────────────────────────

# ── Anthropic Claude (Primary LLM) ──
# Already configured in main .env file
# ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────────────────────────────────────
# OTHER SERVICES
# ──────────────────────────────────────────────────────────────────────────────

# Daytona Sandbox (code execution)
# DAYTONA_SANDBOX_ENABLED=TRUE
# DAYTONA_API_KEY=...
# DAYTONA_API_URL=https://app.daytona.io/api
# DAYTONA_TARGET=us

# ──────────────────────────────────────────────────────────────────────────────
# NOTES
# ──────────────────────────────────────────────────────────────────────────────

# 1. Configuration Priority:
#    RAG_ACTIVE_PROFILE → Profile config → Environment variable overrides
#
# 2. To experiment with configurations:
#    - Edit profiles in rag_config_schema.yaml
#    - Change RAG_ACTIVE_PROFILE
#    - Or use A/B testing to compare
#
# 3. For production:
#    - Set RAG_TRACK_METRICS=true
#    - Set RAG_LOG_RETRIEVAL_RESULTS=false (reduce log volume)
#    - Enable A/B testing to optimize configurations
#
# 4. For development:
#    - Set RAG_DEBUG_MODE=true
#    - Set RAG_SAVE_DEBUG_ARTIFACTS=true
#    - Set RAG_LOG_LEVEL=DEBUG
