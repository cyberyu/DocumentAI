# =============================================================================
# Adaptable Agentic RAG System - Environment Configuration
# =============================================================================
# Add these variables to your existing .env file
# =============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# RAG ORCHESTRATOR CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────

# Active configuration profile
# Options: production | experimental_512 | experimental_semantic | 
#          high_accuracy | fast_cheap | custom
RAG_ACTIVE_PROFILE=production

# Path to RAG configuration file (inside container)
RAG_CONFIG_PATH=/app/app/config/rag_config_schema.yaml

# ──────────────────────────────────────────────────────────────────────────────
# A/B TESTING CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────

# Enable A/B testing to compare configurations
RAG_ENABLE_AB_TESTING=false

# Traffic split: percentage of requests to send to experimental profile
# 0.1 = 10% experimental, 90% production
RAG_AB_TRAFFIC_SPLIT=0.1

# Experimental profile to test against production
RAG_EXPERIMENTAL_PROFILE=experimental_512

# Random seed for consistent A/B assignment (optional)
# RAG_AB_RANDOM_SEED=42

# ──────────────────────────────────────────────────────────────────────────────
# MONITORING & METRICS
# ──────────────────────────────────────────────────────────────────────────────

# Track performance metrics (latency, accuracy, cost)
RAG_TRACK_METRICS=true

# Log detailed retrieval results for debugging
RAG_LOG_RETRIEVAL_RESULTS=true

# Log LLM calls and token usage
RAG_LOG_LLM_CALLS=true

# Metrics export format
# Options: json | prometheus | both
RAG_METRICS_FORMAT=json

# Metrics export interval (seconds)
RAG_METRICS_EXPORT_INTERVAL=60

# ──────────────────────────────────────────────────────────────────────────────
# COMPONENT OVERRIDES (Optional - Config file takes precedence)
# ──────────────────────────────────────────────────────────────────────────────

# ETL configuration
ETL_PROVIDER=mineru  # mineru | docling | unstructured
ETL_EXPORT_FORMAT=markdown
ETL_DETECT_TABLES=true
ETL_DETECT_FORMULAS=true
ETL_TABLE_FORMAT=markdown  # markdown | html | latex | csv
ETL_DPI=300

# Data transformation pipeline
ETL_TRANSFORMATIONS=clean_whitespace,normalize_headers,fix_list_formatting,merge_split_sentences

# Chunking configuration
CHUNKER_CHUNK_SIZE=256
CHUNKER_OVERLAP=0
CHUNKER_STRATEGY=hybrid_sandwich  # hybrid_sandwich | recursive | semantic

# Embedding configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_PROVIDER=fastembed  # fastembed | openai | cohere
EMBEDDING_BATCH_SIZE=32

# Retrieval configuration
RETRIEVAL_MODE=hybrid  # hybrid | vector | bm25
RETRIEVAL_TOP_K=30
RETRIEVAL_RRF_K=60
RETRIEVAL_MAX_CHUNKS_PER_DOC=20

# Reranking configuration
RERANKER_ENABLED=true
RERANKER_PROVIDER=flashrank  # flashrank | cohere | voyage
RERANKER_MODEL=ms-marco-MiniLM-L-12-v2
RERANKER_TOP_K=30

# Adjacent chunk expansion
ADJACENT_EXPANSION_ENABLED=true
ADJACENT_EXPANSION_BEFORE=1
ADJACENT_EXPANSION_AFTER=1

# Context building
CONTEXT_FORMAT=xml_filesystem  # xml_filesystem | markdown | json
CONTEXT_MAX_INDEX_LINES=200
CONTEXT_SHOW_MATCHED_MARKERS=true
CONTEXT_MATCHED_FIRST_ORDERING=true

# ──────────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ──────────────────────────────────────────────────────────────────────────────

# Enable/disable features without code changes
RAG_ENABLE_PROMPT_CACHING=true
RAG_ENABLE_CONTEXT_EXPANSION=true
RAG_ENABLE_MATCHED_FIRST_ORDERING=true
RAG_ENABLE_QUERY_PLANNING=true
RAG_ENABLE_TOOL_SELECTION=true
RAG_ENABLE_PARALLEL_TOOL_CALLS=true
RAG_ENABLE_SUBAGENTS=true
RAG_ENABLE_AUTO_RERANKING=true

# Future features
RAG_ENABLE_FEEDBACK_LOOP=false
RAG_ENABLE_AUTO_OPTIMIZATION=false

# ──────────────────────────────────────────────────────────────────────────────
# EXPERIMENT CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────

# Grid search
RAG_GRID_SEARCH_ENABLED=false
RAG_GRID_SEARCH_BENCHMARK=msft_fy26q1_qa_benchmark_100_sanitized.json
RAG_GRID_SEARCH_PARALLEL_JOBS=4

# Bayesian optimization
RAG_BAYESIAN_OPT_ENABLED=false
RAG_BAYESIAN_OPT_ITERATIONS=50
RAG_BAYESIAN_OPT_OBJECTIVE=maximize_f1_score

# ──────────────────────────────────────────────────────────────────────────────
# PERFORMANCE TUNING
# ──────────────────────────────────────────────────────────────────────────────

# Component caching
RAG_CACHE_EMBEDDING_PROVIDER=true
RAG_CACHE_RETRIEVER=true
RAG_CACHE_RERANKER=true

# Timeout configurations (milliseconds)
RAG_EMBEDDING_TIMEOUT=5000
RAG_RETRIEVAL_TIMEOUT=10000
RAG_RERANKING_TIMEOUT=5000

# Batch processing
RAG_ENABLE_BATCH_EMBEDDING=true
RAG_EMBEDDING_BATCH_SIZE=32

# ──────────────────────────────────────────────────────────────────────────────
# DEVELOPMENT & DEBUGGING
# ──────────────────────────────────────────────────────────────────────────────

# Log level for RAG components
# Options: DEBUG | INFO | WARNING | ERROR
RAG_LOG_LEVEL=INFO

# Enable detailed debug logging
RAG_DEBUG_MODE=false

# Save debug artifacts (query plans, intermediate results)
RAG_SAVE_DEBUG_ARTIFACTS=false
RAG_DEBUG_ARTIFACTS_PATH=/tmp/rag_debug

# Dry run mode (don't actually execute, just plan)
RAG_DRY_RUN=false

# ──────────────────────────────────────────────────────────────────────────────
# OPENSEARCH CONFIGURATION (Vector DB + Full-Text Search)
# ──────────────────────────────────────────────────────────────────────────────

# OpenSearch cluster hosts (comma-separated for multiple nodes)
OPENSEARCH_HOSTS=http://opensearch:9200

# SSL/TLS configuration
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false

# Authentication (if security plugin enabled in production)
# OPENSEARCH_USERNAME=admin
# OPENSEARCH_PASSWORD=admin

# Index configuration
OPENSEARCH_INDEX_PREFIX=surfsense
OPENSEARCH_REFRESH_INTERVAL=1s

# k-NN (vector search) settings
OPENSEARCH_KNN_ENGINE=nmslib  # nmslib | faiss | lucene
OPENSEARCH_KNN_EF_CONSTRUCTION=512
OPENSEARCH_KNN_EF_SEARCH=512
OPENSEARCH_KNN_M=16

# Multiple embedding support
OPENSEARCH_PRIMARY_EMBEDDING=embedding_minilm
OPENSEARCH_ENABLE_SECONDARY_EMBEDDING=false

# OpenSearch Dashboards (monitoring UI)
# Access at http://localhost:5601
# Start with: docker compose --profile monitoring up

# ──────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION (Application Metadata Only)
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL - Now used only for application data (users, sessions, etc.)
# Chunks and embeddings are stored in OpenSearch
DB_USER=surfsense
DB_PASSWORD=surfsense
DB_NAME=surfsense
DB_HOST=db
DB_PORT=5432
DB_SSLMODE=disable

# Redis
REDIS_URL=redis://redis:6379/0

# ──────────────────────────────────────────────────────────────────────────────
# APPLICATION SERVICES
# ──────────────────────────────────────────────────────────────────────────────
BACKEND_PORT=8929
FRONTEND_PORT=3000
NEXT_PUBLIC_FASTAPI_BACKEND_URL=http://localhost:8929

# Zero Cache
ZERO_CACHE_PORT=5929
ZERO_ADMIN_PASSWORD=surfsense-zero-admin
ZERO_APP_PUBLICATIONS=zero_publication

# SurfSense version
SURFSENSE_VERSION=latest

# Search engine
SEARXNG_SECRET=surfsense-searxng-secret
# SEARXNG_DEFAULT_HOST=http://searxng:8080

